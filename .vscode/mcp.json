{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/specification/main/schema/mcp.json",
  "inputs": [
    {
      "type": "promptString",
      "id": "replicate_token",
      "description": "Replicate API token (starts with r8_) — https://replicate.com/account/api-tokens",
      "password": true
    }
  ],
  "servers": {
    "replicate": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "replicate-mcp-server"],
      "env": {
        "REPLICATE_API_TOKEN": "${input:replicate_token}"
      }
    }
  }
}
